#!/bin/bash

OUTPUT_DIR="/tmp/benchmark_$(date +%Y%m%d_%H%M%S)"
REPORT="$OUTPUT_DIR/report.html"
SAR_LOG="$OUTPUT_DIR/sar.log"
PEAK_LOG="$OUTPUT_DIR/peak_analysis.txt"

NFS_MOUNT="/mnt/nfs"   # CHANGE THIS
TEST_SIZE_GB=2

mkdir -p $OUTPUT_DIR

echo "Starting benchmark..."

# ========= SYSTEM INFO =========
HOSTNAME=$(hostname)
DATE=$(date)
CPU=$(lscpu | grep "Model name" | awk -F: '{print $2}')
CORES=$(nproc)
MEM=$(free -h | grep Mem | awk '{print $2}')

# ========= START SAR =========
sar -u -r -d -n DEV 1 > $SAR_LOG &
SAR_PID=$!

# ========= CPU LOAD =========
for i in $(seq 1 $CORES); do yes > /dev/null & done
sleep 10
killall yes 2>/dev/null

# ========= MEMORY =========
dd if=/dev/zero of=/dev/shm/mem_test bs=1M count=1024 &>/dev/null
rm -f /dev/shm/mem_test

# ========= DISK =========
TEST_FILE="$OUTPUT_DIR/testfile"

sync; echo 3 > /proc/sys/vm/drop_caches
START=$(date +%s)
dd if=/dev/zero of=$TEST_FILE bs=1G count=$TEST_SIZE_GB oflag=direct &>/dev/null
END=$(date +%s)
WRITE_MBPS=$((TEST_SIZE_GB * 1024 / (END-START)))

sync; echo 3 > /proc/sys/vm/drop_caches
START=$(date +%s)
dd if=$TEST_FILE of=/dev/null bs=1G &>/dev/null
END=$(date +%s)
READ_MBPS=$((TEST_SIZE_GB * 1024 / (END-START)))

# ========= NFS =========
NFS_FILE="$NFS_MOUNT/testfile"

START=$(date +%s)
cp $TEST_FILE $NFS_FILE
END=$(date +%s)
NFS_WRITE_MBPS=$((TEST_SIZE_GB * 1024 / (END-START)))

START=$(date +%s)
cp $NFS_FILE ${TEST_FILE}_read
END=$(date +%s)
NFS_READ_MBPS=$((TEST_SIZE_GB * 1024 / (END-START)))

rm -f $TEST_FILE ${TEST_FILE}_read $NFS_FILE

# ========= STOP SAR =========
kill $SAR_PID

# ========= PEAK ANALYSIS (LAST 30 DAYS) =========
echo "Running 30-day peak analysis..."

echo "" > $PEAK_LOG

for f in /var/log/sa/sa??; do
    [ -f "$f" ] || continue

    DAY=$(basename $f)

    # Find peak CPU usage time (lowest idle)
    PEAK_TIME=$(sar -u -f $f | awk '
        $0 ~ /^[0-9]/ {
            idle=$(NF);
            if (min=="" || idle < min) {
                min=idle;
                time=$1
            }
        }
        END { print time }')

    if [ ! -z "$PEAK_TIME" ]; then
        START_TIME=$PEAK_TIME
        END_TIME=$(date -d "$PEAK_TIME + 1 hour" +%H:%M:%S)

        echo "===== $DAY Peak Hour: $START_TIME - $END_TIME =====" >> $PEAK_LOG

        sar -u -f $f -s $START_TIME -e $END_TIME >> $PEAK_LOG
        sar -r -f $f -s $START_TIME -e $END_TIME >> $PEAK_LOG
        sar -d -f $f -s $START_TIME -e $END_TIME >> $PEAK_LOG
        sar -n DEV -f $f -s $START_TIME -e $END_TIME >> $PEAK_LOG

        echo "" >> $PEAK_LOG
    fi

done

# ========= HTML =========
cat <<EOF > $REPORT
<html>
<head>
<title>Benchmark Report</title>
<style>
body { font-family: Arial; }
h1 { color: #2c3e50; }
table { border-collapse: collapse; width: 60%; }
th, td { border: 1px solid #ddd; padding: 8px; }
th { background-color: #f2f2f2; }
pre { background: #f4f4f4; padding: 10px; }
</style>
</head>
<body>

<h1>Server Benchmark Report</h1>

<h2>System Info</h2>
<table>
<tr><th>Host</th><td>$HOSTNAME</td></tr>
<tr><th>Date</th><td>$DATE</td></tr>
<tr><th>CPU</th><td>$CPU</td></tr>
<tr><th>Cores</th><td>$CORES</td></tr>
<tr><th>Memory</th><td>$MEM</td></tr>
</table>

<h2>Disk Performance</h2>
<table>
<tr><th>Write</th><td>${WRITE_MBPS} MB/s</td></tr>
<tr><th>Read</th><td>${READ_MBPS} MB/s</td></tr>
</table>

<h2>NFS Performance</h2>
<table>
<tr><th>Write</th><td>${NFS_WRITE_MBPS} MB/s</td></tr>
<tr><th>Read</th><td>${NFS_READ_MBPS} MB/s</td></tr>
</table>

<h2>Recent SAR (Live Test)</h2>
<pre>
$(tail -n 100 $SAR_LOG)
</pre>

<h2>30-Day Peak Hour Analysis</h2>
<pre>
$(cat $PEAK_LOG)
</pre>

</body>
</html>
EOF

echo "✅ Done!"
echo "📄 Report: $REPORT"
